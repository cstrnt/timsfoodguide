---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<hr class="footer-rule" />
		<div class="footer-content">
			<span class="footer-title">{SITE_TITLE}</span>
			<span class="footer-sep">·</span>
			<span class="footer-copy">&copy; {today.getFullYear()} {SITE_AUTHOR}</span>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 0 1.5em 3em;
		background: var(--cream);
	}

	.footer-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.footer-rule {
		border-top: 1px solid var(--rule);
		margin-bottom: 1.25em;
	}

	.footer-content {
		display: flex;
		align-items: center;
		gap: 0.75em;
		font-family: var(--sans);
		font-size: 0.75em;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-muted);
	}

	.footer-title {
		font-family: var(--serif);
		font-size: 1.1em;
		letter-spacing: 0;
		text-transform: none;
		color: var(--ink);
	}

	.footer-sep {
		color: var(--rule);
	}
</style>
