---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="masthead">
		<div class="rule-double">
			<hr class="thick" />
			<hr class="thin" />
		</div>
		<div class="masthead-inner">
			<a href="/" class="masthead-title">{SITE_TITLE}</a>
			<p class="masthead-tagline">Independent restaurant reviews</p>
		</div>
		<hr class="rule-single" />
		<nav>
			<HeaderLink href="/">Latest</HeaderLink>
			<span class="nav-sep">·</span>
			<HeaderLink href="/countries">Countries</HeaderLink>
			<span class="nav-sep">·</span>
			<HeaderLink href="/type">By Type</HeaderLink>
			<span class="nav-sep">·</span>
			<HeaderLink href="/about">About</HeaderLink>
		</nav>
		<hr class="rule-single" />
	</div>
</header>

<style>
	header {
		background: var(--cream);
		padding: 0 1.5em;
	}

	.masthead {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding-top: 1.5em;
	}

	.rule-double {
		display: flex;
		flex-direction: column;
		gap: 3px;
		margin-bottom: 1.2em;
	}

	.rule-double .thick {
		border-top: 3px solid var(--ink);
	}

	.rule-double .thin {
		border-top: 1px solid var(--ink);
	}

	.rule-single {
		border-top: 1px solid var(--rule);
		margin: 0;
	}

	.masthead-inner {
		text-align: center;
		margin-bottom: 1em;
	}

	.masthead-title {
		font-family: var(--serif);
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 700;
		letter-spacing: -0.01em;
		color: var(--ink);
		text-decoration: none;
		display: block;
		line-height: 1.1;
	}

	.masthead-title:hover {
		color: var(--accent);
	}

	.masthead-tagline {
		font-family: var(--sans);
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin: 0.4em 0 0;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75em;
		padding: 0.6em 0;
	}

	nav :global(a) {
		font-family: var(--sans);
		font-size: 0.8em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--ink-muted);
		transition: color 0.15s ease;
	}

	nav :global(a:hover),
	nav :global(a.active) {
		color: var(--ink);
	}

	.nav-sep {
		color: var(--rule);
		font-family: var(--sans);
	}
</style>
