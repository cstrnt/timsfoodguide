---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { toSlug } from '../lib/taxonomy';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, pubDate, heroImage, place, ratings, type, city } = post.data;
---

<a href={`/blog/${post.id}/`} class="post-card">
	{
		heroImage && (
			<div class="card-image">
				<Image src={heroImage} alt={title} width={480} height={300} />
			</div>
		)
	}
	<div class="card-content">
		<div class="card-meta">
			{
				type && (
					<a
						href={`/type/${toSlug(type)}`}
						class="meta-tag meta-type"
						onclick="event.stopPropagation()"
					>
						{type}
					</a>
				)
			}
			{type && city && <span class="meta-sep">·</span>}
			{
				city && (
					<a
						href={`/cities/${toSlug(city)}`}
						class="meta-tag meta-city"
						onclick="event.stopPropagation()"
					>
						{city}
					</a>
				)
			}
		</div>
		{place && <span class="post-place">{place}</span>}
		<h3 class="card-title">{title}</h3>
		<div class="post-footer-meta">
			{
				ratings && (
					<span class="compact-ratings">
						Food {ratings.food} &middot; Vibe {ratings.vibe} &middot; Value {ratings.value}
					</span>
				)
			}
			<span class="post-date"><FormattedDate date={pubDate} /></span>
		</div>
	</div>
</a>

<style>
	.post-card {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.post-card:hover .card-title {
		color: var(--accent);
	}

	.card-image img {
		display: block;
		width: 100%;
		height: 220px;
		object-fit: cover;
		margin-bottom: 0.85em;
	}

	.card-content {
		padding: 0;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.4em;
		margin-bottom: 0.3em;
	}

	.meta-tag {
		font-family: var(--sans);
		font-size: 0.65em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-decoration: none;
		transition: color 0.15s;
	}

	.meta-type {
		color: var(--accent);
	}

	.meta-type:hover {
		color: var(--ink);
	}

	.meta-city {
		color: var(--ink-muted);
	}

	.meta-city:hover {
		color: var(--ink);
	}

	.meta-sep {
		font-family: var(--sans);
		font-size: 0.65em;
		color: var(--rule);
	}

	.post-place {
		font-family: var(--sans);
		font-size: 0.72em;
		letter-spacing: 0.06em;
		color: var(--ink);
		display: block;
		margin-bottom: 0.2em;
	}

	.card-title {
		font-family: var(--serif);
		font-size: 1.2em;
		font-weight: 700;
		line-height: 1.3;
		margin: 0 0 0.5em;
		color: var(--ink);
		transition: color 0.15s;
	}

	.post-footer-meta {
		display: flex;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}

	.compact-ratings {
		font-family: var(--sans);
		font-size: 0.7em;
		letter-spacing: 0.05em;
		color: var(--ink-muted);
	}

	.post-date {
		font-family: var(--sans);
		font-size: 0.7em;
		letter-spacing: 0.06em;
		color: var(--ink-muted);
		text-transform: uppercase;
	}
</style>
