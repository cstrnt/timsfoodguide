---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { toSlug } from '../lib/taxonomy';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, place, location, ratings, gallery, city, country, type } =
	Astro.props;

const dots = (n: number) =>
	Array.from({ length: 5 }, (_, i) => (i < n ? '●' : '○')).join('');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />

		<main class="post-main">
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image src={heroImage} alt={title} width={1100} height={550} />
						</div>
					)
				}

				<div class="post-header">
					<div class="post-meta">
						<div class="meta-taxonomy">
							{
								type && (
									<a href={`/type/${toSlug(type)}`} class="meta-type">
										{type}
									</a>
								)
							}
							{type && city && <span class="meta-sep">·</span>}
							{
								city && (
									<a href={`/cities/${toSlug(city)}`} class="meta-city">
										{city}
									</a>
								)
							}
							{city && country && <span class="meta-sep">·</span>}
							{
								country && (
									<a href={`/countries/${toSlug(country)}`} class="meta-country">
										{country}
									</a>
								)
							}
						</div>
						{
							(place || location) && (
								<span class="post-place">
									{place}
									{place && location && <span class="place-sep"> — </span>}
									{location && <span class="post-location">{location}</span>}
								</span>
							)
						}
						<span class="post-date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="post-updated">
										{' '}
										(updated <FormattedDate date={updatedDate} />)
									</span>
								)
							}
						</span>
					</div>

					<h1 class="post-title">{title}</h1>

					{description && <p class="post-description">{description}</p>}

					{
						ratings && (
							<div class="ratings-block">
								<div class="rating-item">
									<span class="rating-label">Food</span>
									<span class="rating-dots" title={`${ratings.food}/5`}>
										{dots(ratings.food)}
									</span>
								</div>
								<div class="rating-divider" />
								<div class="rating-item">
									<span class="rating-label">Vibe</span>
									<span class="rating-dots" title={`${ratings.vibe}/5`}>
										{dots(ratings.vibe)}
									</span>
								</div>
								<div class="rating-divider" />
								<div class="rating-item">
									<span class="rating-label">Value</span>
									<span class="rating-dots" title={`${ratings.value}/5`}>
										{dots(ratings.value)}
									</span>
								</div>
							</div>
						)
					}

					<hr class="post-rule" />
				</div>

				<div class="prose">
					<slot />
				</div>

				{
					gallery && gallery.length > 0 && (
						<div class="gallery-section">
							<hr class="gallery-rule" />
							<h2 class="gallery-heading">Gallery</h2>
							<div class="gallery-grid">
								{gallery.map((img) => (
									<div class="gallery-item">
										<Image src={img} alt="" />
									</div>
								))}
							</div>
						</div>
					)
				}
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	.post-main {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 1.5em 4em;
	}

	/* Hero image */
	.hero-image {
		margin: 2em 0 0;
	}

	.hero-image img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 580px;
		object-fit: cover;
	}

	/* Post header */
	.post-header {
		max-width: var(--content-width);
		margin: 2em auto 0;
		padding: 0 1em;
		text-align: center;
	}

	.post-meta {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5em;
		font-family: var(--sans);
		font-size: 0.72em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin-bottom: 1em;
	}

	.meta-taxonomy {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.meta-type {
		color: var(--accent);
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.meta-type:hover {
		opacity: 0.7;
	}

	.meta-city,
	.meta-country {
		color: var(--ink-muted);
		text-decoration: none;
		transition: color 0.15s;
	}

	.meta-city:hover,
	.meta-country:hover {
		color: var(--ink);
	}

	.post-place {
		font-weight: 600;
		color: var(--ink);
	}

	.place-sep {
		color: var(--rule);
	}

	.meta-sep {
		color: var(--rule);
		font-weight: 400;
	}

	.post-location {
		font-weight: 400;
	}

	.post-updated {
		font-style: italic;
		letter-spacing: 0;
		text-transform: none;
	}

	.post-title {
		font-family: var(--serif);
		font-size: clamp(2em, 4.5vw, 3.2em);
		font-weight: 700;
		line-height: 1.15;
		margin: 0 0 0.6em;
		color: var(--ink);
	}

	.post-description {
		font-family: var(--body-serif);
		font-style: italic;
		font-size: 1.15em;
		color: var(--ink-muted);
		line-height: 1.5;
		margin: 0 0 1.5em;
	}

	/* Ratings */
	.ratings-block {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0;
		margin: 0 0 1.5em;
		flex-wrap: wrap;
	}

	.rating-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3em;
		padding: 0.75em 1.5em;
	}

	.rating-label {
		font-family: var(--sans);
		font-size: 0.65em;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--ink-muted);
	}

	.rating-dots {
		font-size: 0.85em;
		letter-spacing: 0.15em;
		color: var(--accent);
		font-family: var(--sans);
	}

	.rating-divider {
		width: 1px;
		height: 2.5em;
		background: var(--rule);
	}

	.post-rule {
		border-top: 1px solid var(--rule);
		margin: 0;
	}

	/* Prose */
	.prose {
		max-width: var(--content-width);
		margin: 2.5em auto 0;
		padding: 0 1em;
		font-size: 1.05em;
	}

	.prose :global(h2) {
		font-size: 1.6em;
		margin: 2em 0 0.5em;
	}

	.prose :global(h3) {
		font-size: 1.25em;
		margin: 1.75em 0 0.4em;
	}

	.prose :global(img) {
		width: 100%;
		margin: 1.5em 0;
	}

	/* Gallery */
	.gallery-section {
		max-width: var(--wide-width);
		margin: 3em auto 0;
		padding: 0 1em;
	}

	.gallery-rule {
		border-top: 1px solid var(--rule);
		margin-bottom: 2em;
	}

	.gallery-heading {
		font-family: var(--sans);
		font-size: 0.7em;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin: 0 0 1.25em;
		font-weight: 400;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 0.75em;
	}

	.gallery-item img {
		width: 100%;
		height: 260px;
		object-fit: cover;
		display: block;
	}

	@media (max-width: 720px) {
		.post-main {
			padding: 0 1em 3em;
		}

		.post-header {
			padding: 0;
		}

		.prose {
			padding: 0;
		}

		.ratings-block {
			gap: 0;
		}

		.rating-item {
			padding: 0.75em 1em;
		}

		.gallery-grid {
			grid-template-columns: 1fr 1fr;
			gap: 0.5em;
		}

		.gallery-item img {
			height: 180px;
		}
	}
</style>
