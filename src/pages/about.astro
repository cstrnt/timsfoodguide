---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="section-header">
				<span class="section-label">About</span>
				<hr />
			</div>
			<div class="about-content">
				<h1>About This Guide</h1>
				<p>
					I'm Tim, and I eat out a lot. This is where I write about the places that stuck with me —
					the ones worth going back to, and occasionally the ones worth a warning.
				</p>
				<p>
					Every review includes three honest scores: <strong>Food</strong> for what's on the plate,
					<strong>Vibe</strong> for the atmosphere and service, and <strong>Value</strong> for whether
					it's worth what you pay.
				</p>
				<p>No sponsored content. No PR dinners. Just my own tab.</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.section-header {
		margin-bottom: 2em;
	}

	.section-label {
		display: block;
		font-family: var(--sans);
		font-size: 0.7em;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin-bottom: 0.6em;
	}

	.about-content {
		max-width: var(--content-width);
	}

	.about-content h1 {
		font-size: 2.2em;
		margin-bottom: 0.75em;
	}

	.about-content p {
		font-size: 1.1em;
		line-height: 1.75;
		color: var(--ink);
	}
</style>
